{
    "name": "wizdam/jats-engine",
    "description": "Convert DOCX Manuscripts into JATS XML for Scholarly Publishing",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "jats",
        "xml",
        "docx",
        "scholarly-publishing",
        "ojs",
        "journal"
    ],
    "authors": [
        {
            "name": "Rochmady",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-zip": "*",
        "ext-libxml": "*",
        "ext-xsl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "ext-imagick": "Required for converting EMF/WMF metafiles to PNG"
    },
    "autoload": {
        "psr-4": {
            "Wizdam\\JatsEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wizdam\\JatsEngine\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
